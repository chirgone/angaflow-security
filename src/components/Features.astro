---
import { type Locale, useTranslations } from '@i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const iconPaths: Record<string, string> = {
  'shield-check': 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4',
  'swords': 'm14.5 17.5 3 3 3-3M2 2l7.586 7.586m0 0L11 11m-1.414-1.414L11 11m0 0 3.5 3.5M2 22l7.586-7.586m0 0L11 13m-1.414 1.414L11 13m0 0-1.5-1.5M22 2l-7.586 7.586',
  'wrench': 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  'badge-check': 'M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76z M9 12l2 2 4-4',
  'bar-chart-3': 'M12 20V10 M18 20V4 M6 20v-4',
  'headset': 'M3 18v-6a9 9 0 0 1 18 0v6 M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z',
};

const iconColors = [
  'text-primary',
  'text-danger',
  'text-success',
  'text-secondary',
  'text-warning',
  'text-accent',
];

const bgColors = [
  'from-primary/10 to-primary/5',
  'from-danger/10 to-danger/5',
  'from-success/10 to-success/5',
  'from-secondary/10 to-secondary/5',
  'from-warning/10 to-warning/5',
  'from-accent/10 to-accent/5',
];
---

<section id="features" class="relative py-24 lg:py-32">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/[0.02] to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Overline & Title -->
    <div class="text-center mb-16 reveal">
      <span class="text-xs font-semibold uppercase tracking-widest text-primary">{t.features.overline}</span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        {t.features.title}
      </h2>
    </div>

    <!-- Feature Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {t.features.items.map((feature, i) => (
        <div class={`reveal card-gradient p-8 hover:bg-bg-surface-hover transition-colors group relative ${feature.comingSoon ? 'opacity-75' : ''}`}>
          {/* Coming Soon badge */}
          {feature.comingSoon && (
            <div class="absolute top-4 right-4">
              <span class="inline-flex items-center rounded-full bg-warning/10 border border-warning/30 px-3 py-1 text-xs font-semibold text-warning">
                {lang === 'es' ? 'Pr\u00f3ximamente' : 'Coming Soon'}
              </span>
            </div>
          )}

          {/* Icon */}
          <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br ${bgColors[i]} mb-6`}>
            <svg class={`w-7 h-7 ${iconColors[i]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {iconPaths[feature.icon]?.split(' M').map((segment, j) => (
                <path d={j === 0 ? segment : `M${segment}`}/>
              ))}
            </svg>
          </div>

          <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">{feature.title}</h3>
          <p class="text-text-secondary leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
