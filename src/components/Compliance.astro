---
import { type Locale, useTranslations } from '@i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative py-24 lg:py-32">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-warning/[0.02] to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Overline & Title -->
    <div class="text-center mb-6 reveal">
      <span class="text-xs font-semibold uppercase tracking-widest text-warning">{t.compliance.overline}</span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        {t.compliance.title}
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">{t.compliance.subtitle}</p>
    </div>

    <!-- Requires badge -->
    <div class="text-center mb-12 reveal">
      <span class="inline-flex items-center rounded-full border border-primary/30 bg-primary/5 px-4 py-1.5 text-xs font-semibold text-primary">
        {t.compliance.requires}
      </span>
    </div>

    <!-- Frameworks Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-5xl mx-auto mb-10">
      {t.compliance.frameworks.map((fw) => (
        <div class="reveal card-gradient p-6 text-center hover:bg-bg-surface-hover transition-colors group">
          <div class="text-lg font-bold mb-1">{fw.name}</div>
          <div class="text-xs text-text-muted mb-4">{fw.region}</div>
          <div class="text-2xl font-extrabold font-mono text-warning">{fw.credits}</div>
          <div class="text-xs text-text-muted mb-3">{t.compliance.credits_label}</div>
          <div class="inline-flex items-center rounded-full bg-bg-surface px-3 py-1 text-xs text-text-secondary">
            {fw.controls} {t.compliance.controls_label}
          </div>
        </div>
      ))}
    </div>

    <!-- Bundle -->
    <div class="reveal text-center space-y-3">
      <div class="inline-flex items-center gap-3 rounded-2xl border border-warning/30 bg-warning/5 px-8 py-4">
        <span class="text-base font-bold">{t.compliance.bundle}</span>
        <span class="inline-flex items-center rounded-full bg-success/10 border border-success/30 px-3 py-1 text-xs font-bold text-success">
          {t.compliance.bundle_savings}
        </span>
      </div>
      <div class="text-sm text-text-muted">{t.compliance.bundle_controls}</div>
    </div>
  </div>
</section>
