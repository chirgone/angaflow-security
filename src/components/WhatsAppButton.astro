---
import { type Locale, useTranslations } from '@i18n/utils';

interface Props {
  lang: Locale;
  phone?: string;
}

const { lang, phone = '525551575041' } = Astro.props;
const t = useTranslations(lang);
const message = encodeURIComponent(t.whatsapp.message);
const href = `https://wa.me/${phone}?text=${message}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] text-white shadow-2xl hover:scale-110 transition-transform animate-whatsapp"
  aria-label="WhatsApp"
>
  <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 2a10 10 0 0 0-8.535 15.15L2 22l4.85-1.465A10 10 0 1 0 12 2zm0 18.3a8.3 8.3 0 0 1-4.235-1.158l-.304-.18-3.148.95.83-3.03-.198-.314A8.3 8.3 0 1 1 12 20.3z" fill-rule="evenodd"/>
  </svg>
</a>
