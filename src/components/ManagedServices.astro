---
import { type Locale, useTranslations } from '@i18n/utils';
import ManagedServicesButton from './ManagedServicesButton';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="managed" class="relative py-24 lg:py-32">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-accent/[0.02] to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Overline & Title -->
    <div class="text-center mb-16 reveal">
      <span class="text-xs font-semibold uppercase tracking-widest text-accent">{t.managed.overline}</span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        {t.managed.title}
      </h2>
      <p class="mt-6 text-lg text-text-secondary max-w-2xl mx-auto">{t.managed.subtitle}</p>
    </div>

    <!-- CTA Button -->
    <div class="flex justify-center">
      <ManagedServicesButton lang={lang} ctaText={t.managed.cta} client:load />
    </div>
  </div>
</section>
